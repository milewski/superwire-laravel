provider openai {
    driver: "openai"
    endpoint: "http://example.test/v1"
    api_key: secrets.api_key
    models: [secrets.model]
}

secrets {
    api_key: string
    model: string
}

input {
    min: number
    max: number
}

agent numbers {
    model: openai(secrets.model)
    prompt: "generate a sequence of numbers from {{ input.min }} to {{ input.max }}."
    output: [number]
}

agent counter for number in agent.numbers {
    model: openai(secrets.model)
    prompt: "spell out this number: {{ number }}."
    output: string
}

output {
    numbers: agent.counter
}
