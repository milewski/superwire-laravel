provider openai {
    driver: "openai"
    endpoint: "http://example.test/v1"
    api_key: "test-key"
    models: ["test-model"]
}

agent release_analyst {
    model: openai("test-model")

    inference: {
        temperature: 0.2
        max_tokens: 12000
        top_p: 0.9
    }

    prompt: "Write a short release readiness note."
    output: string
}

output {
    note: agent.release_analyst
}
