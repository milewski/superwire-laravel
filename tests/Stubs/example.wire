provider openai {
    driver: "openai"
    endpoint: "http://100.76.5.36:1234/v1"
    api_key: "test-key"
    models: ["qwen/qwen3.6-27b"]
}

agent lister {
    model: openai("qwen/qwen3.6-27b")
    prompt: "Write a list of numbers from 1 to 5"
    output: {
        numbers: [number]
    }
}

agent counter for item in agent.lister.numbers {
    model: openai("qwen/qwen3.6-27b")
    prompt: "spell out the number: {{ item }} in lowercase."
    output: string
}

output {
    numbers: agent.counter
}
