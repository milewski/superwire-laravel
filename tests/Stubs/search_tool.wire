provider openai {
    driver: "openai"
    endpoint: "http://example.test/v1"
    api_key: "test-key"
    models: ["test-model"]
}

tool search {
    input {
        query: string
    }

    bindings {
        tenant_id: string
    }
}

agent assistant {
    model: openai("test-model")
    tools: [
        tool.search {
            bindings {
                tenant_id: "tenant-123"
            }
        },
    ]
    prompt: "Search."
    output: string
}

output {
    answer: agent.assistant
}
