provider openai {
    driver: "openai"
    endpoint: "http://example.test/v1"
    api_key: "test-key"
    models: ["test-model"]
}

agent customer_story {
    model: openai("test-model")
    prompt: "Write customer story."
    output: string
}

agent investor_story {
    model: openai("test-model")
    prompt: "Write investor story."
    output: string
}

agent review {
    model: openai("test-model")
    prompt: "Combine {{ agent.customer_story }} and {{ agent.investor_story }}."
    output: string
}

output {
    review: agent.review
}
