provider openai {
    driver: "openai"
    endpoint: "http://example.test/v1"
    api_key: "test-key"
    models: ["test-model"]
}

agent all_types {
    model: openai("test-model")
    prompt: "Return all supported types."
    output: {
        string_value: string
        number_value: number
        float_value: float
        boolean_value: boolean
        explicit_null: null
        nullable_string: string | null
        nullable_number: number | null
        array: [string]
        fixed_array: [string; 3]
        array_of_objects: [{
            id: string
            score: number
        }]
        enum_value: "draft" | "ready" | "published"
        nullable_enum: "draft" | "ready" | "published" | null
        tuple_value: (string, number, [string; 3])
        nullable_tuple: (string, number, [string; 3]) | null
        object_value: {
            string_value: string
            number_value: number
        }
        nullable_object: {
            string_value: string
            number_value: number
        } | null
    }
}

output {
    all_types: agent.all_types
}
