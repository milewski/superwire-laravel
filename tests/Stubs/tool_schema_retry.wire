provider openai {
    driver: "openai"
    endpoint: "http://example.test/v1"
    api_key: "test-key"
    models: ["test-model"]
}

tool bound_schema_tool {
    input {
        city: string
    }

    bindings {
        tenant_id: string
    }
}

tool retry_weather_tool {
    input {
        city: string
    }
}

agent assistant {
    model: openai("test-model")
    tools: [
        tool.bound_schema_tool {
            bindings {
                tenant_id: "tenant-123"
            }
        },
        tool.retry_weather_tool
    ]
    prompt: "Use the weather tool and finish with the weather summary."
    output: {
        weather: string
    }
}

output {
    weather: agent.assistant.weather
}
